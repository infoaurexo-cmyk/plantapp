PORT=3000
NODE_ENV=production
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
PLANTNET_API_KEY=YOUR_PLANTNET_API_KEY

# PostgreSQL Database Configuration
# Railway will inject these environment variables automatically when PostgreSQL is added
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=plant_app

CORS_ORIGIN=*
